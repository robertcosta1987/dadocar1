# ─── Dadocar aggregator endpoint (Azure Function App) ──────────────────────
# The Vercel app no longer calls Infocar directly. It proxies through the
# enrichment-function in Azure, which holds vendor credentials in Key Vault
# and runs all providers. Set both vars in the Vercel project (Production +
# Preview scopes) and locally in this file.
AZURE_FUNCTION_URL=https://dadocar-dev-func-enrich-brs.azurewebsites.net
AZURE_FUNCTION_KEY=

# ─── Shared-secret gate ─────────────────────────────────────────────────────
# Bearer token required on every /api/* request from the browser.
# Generate with `openssl rand -hex 24`.
#   - On Vercel: REQUIRED. If unset, every API call returns 503.
#   - Locally:   OPTIONAL. If unset, the local proxy is open (handy on
#                `localhost`). The Vercel deploy is always gated.
DADOCAR_GATE_SECRET=

# ─── Local proxy options ────────────────────────────────────────────────────
PORT=3001
