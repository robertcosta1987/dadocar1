# ─── Infocar credentials ────────────────────────────────────────────────────
# Fill these in once the customer's Infocar account is activated. Until then
# the proxy / serverless functions return 503 credentials_missing so the UI
# can still load and exercise validation.
INFOCAR_ID_KEY=
INFOCAR_USERNAME=
INFOCAR_PASSWORD=

# ─── Shared-secret gate ─────────────────────────────────────────────────────
# Bearer token required on every /api/* request. Set this to any reasonably
# random value (e.g. `openssl rand -hex 24`). The frontend prompts the user
# for it on first load and stores it in sessionStorage.
#
# Behavior:
#   - On Vercel: REQUIRED. If not set, every API call returns 503
#     gate_unconfigured to force you to configure it.
#   - Locally:   OPTIONAL. If unset, the local proxy is open (convenient
#     for dev on `localhost`). The Vercel deploy is always gated.
DADOCAR_GATE_SECRET=

# ─── Local proxy options ────────────────────────────────────────────────────
PORT=3001
