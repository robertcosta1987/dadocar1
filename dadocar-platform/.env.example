# ─────────────────────────────────────────────────────────────────────────────
# Dadocar — local environment template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# `.env` is sourced by humans before running infrastructure/scripts/*.sh.
#
# The Infocar credentials below are only used by apps/infocar-test/ — they
# never appear in Bicep or in any Azure resource. Real Infocar secrets get
# stored in Key Vault later, manually, via `az keyvault secret set` once the
# customer's credentials are activated. See docs/dev-setup.md.
# ─────────────────────────────────────────────────────────────────────────────

# Azure Service Principal — used by all infrastructure/scripts/*.sh
# The SP must have either Owner, OR (Contributor + User Access Administrator)
# on the target subscription.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# Optional — overrides the default RG name (rg-dadocar-dev-brs) at deploy time.
# Leave unset to use the default.
# DADOCAR_RG_NAME=rg-dadocar-dev-brs

# Optional — overrides the default region (brazilsouth).
# DADOCAR_LOCATION=brazilsouth
