# OpenAI (same key as the Placas360 web/WhatsApp bot)
OPENAI_API_KEY=
OPENAI_AUDIO_MODEL=gpt-audio
OPENAI_MODEL=gpt-5-mini
OPENAI_VOICE=coral
# WasenderAPI (same session key + WhatsApp number as the existing bot)
WASENDER_API_KEY=
WASENDER_API_BASE=https://www.wasenderapi.com/api
WASENDER_WEBHOOK_SECRET=
# Public URL this service is reachable at (used to build the audio reply URL)
PUBLIC_BASE_URL=https://lisa-voice-bot.onrender.com
MAX_HISTORY=12

# ── White-label multi-tenant ────────────────────────────────────────────────
# Separate store for tenants + usage. Azure Table Storage connection string.
# If empty, an in-memory store is used (NOT durable — dev/single-tenant only).
LISA_STORE_CONN=
# Bearer token guarding the /admin API + console. REQUIRED to manage tenants.
LISA_ADMIN_TOKEN=
# Owner tenant (the existing Lisa) — answers the bare /webhook path. 0 = unlimited.
LISA_DEFAULT_TENANT=placas360
LISA_DEFAULT_TENANT_NAME=Placas360
LISA_DEFAULT_VOICE_MIN=0
LISA_DEFAULT_TEXT_MSGS=0
# Plan template pre-filled for NEW customers in the admin console.
LISA_PLAN_VOICE_MIN=100
LISA_PLAN_TEXT_MSGS=500
# OpenAI unit prices (USD / 1M tokens) for the cost/margin view (defaults shown).
PRICE_AUDIO_IN=32
PRICE_AUDIO_OUT=64
PRICE_TEXT_IN=2.5
PRICE_TEXT_OUT=10
PRICE_MINI_IN=0.25
PRICE_MINI_OUT=2
