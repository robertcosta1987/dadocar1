# ─── Secrets — never commit ────────────────────────────────────────────────
.env
.env.*
!.env.example
*.env.local
*.bicepparam.local
# Common credential-dump filenames. Narrow patterns so they don't catch
# legitimate source code that *handles* secrets (e.g. src/lib/secrets.js).
*.secret
*.secrets
secrets.json
credentials.json
*-credentials.json
*.credentials

# ─── Bicep build artifacts ─────────────────────────────────────────────────
*.bicep.json
infrastructure/bicep/**/*.json
!infrastructure/bicep/**/*.bicepparam

# ─── Node ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log
.pnp.*

# ─── Editor / OS ───────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
Thumbs.db

# ─── Az CLI caches that sometimes get dropped in repo dirs ─────────────────
.azure/
